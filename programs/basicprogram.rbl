class System
	staticdef int Init()
		return Main$main();
	end
end

class Main
	staticdef int main()
		return $fib(7);
	end

	staticdef int fib(int amount)
		local int i, last1, last2, result;
		let i = 0;
		let last1 = 1;
		let last2 = 1;

		while (i < (amount-2)) do
			let result = last1 + last2;
			let last1 = last2;
			let last2 = result;
			
			let i = i + 1;
		end

		return last2;
	end
end
